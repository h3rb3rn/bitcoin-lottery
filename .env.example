# ── Pool credentials ────────────────────────────────────────────────────────
MINER_POOL_URL=stratum+tcp://solo.ckpool.org:3333
MINER_WALLET=your_bitcoin_address_here
MINER_PASSWORD=x

# ── Hardware ─────────────────────────────────────────────────────────────────
# Oscillator frequency for the Bitfury chip (valid range: 48–56).
# Higher = more hashrate and heat. Default: 54
OSC6_BITS=54

# ── Bitcoin ──────────────────────────────────────────────────────────────────
# Current block reward in BTC. Update after each halving.
BLOCK_REWARD_BTC=3.125

# ── Miners ───────────────────────────────────────────────────────────────────
# Define up to 10 miners with MINER_N_* vars. The monitor will poll each one
# independently and show per-miner + aggregate views in the dashboard.
#
# Supported types: bfgminer | cgminer | antminer | whatsminer | bitaxe
#
MINER_1_NAME=NanoFury NF2
MINER_1_TYPE=bfgminer
MINER_1_HOST=nanofury_lottery
MINER_1_PORT=4028
#
# MINER_2_NAME=Antminer S9
# MINER_2_TYPE=antminer
# MINER_2_HOST=192.168.1.50
# MINER_2_PORT=80
# MINER_2_USER=root
# MINER_2_PASSWORD=root
#
# MINER_3_NAME=Bitaxe Ultra
# MINER_3_TYPE=bitaxe
# MINER_3_HOST=192.168.1.60
# MINER_3_PORT=80

# Legacy single-miner fallback (used only if no MINER_N_* vars are set)
BFGMINER_HOST=nanofury_lottery
BFGMINER_PORT=4028

# ── Monitor ───────────────────────────────────────────────────────────────────
# Public URL of the dashboard — appears in email links.
MONITOR_URL=http://YOUR_SERVER_IP:8080

# ── SMTP email alerts ─────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable all email alerts.
# Alerts sent for: miner offline, miner recovered, block found, weekly report.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=miner@example.com
SMTP_PASSWORD=secret
SMTP_FROM=miner@example.com
SMTP_TO=you@example.com
# true  = STARTTLS on SMTP_PORT (typically 587)
# false = implicit TLS / SMTP_SSL (typically 465)
SMTP_STARTTLS=true
