# NanoFury NF2 USB Bitcoin Miner (Microchip 04d8:00de)
# Grants read/write access to all users so libusb inside Docker can open the device.
# Also unbinds the usbhid kernel driver that would otherwise claim the HID interface,
# since BFGMiner communicates with the Bitfury chip directly via the raw HID protocol.

SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="00de", MODE="0666", GROUP="plugdev", TAG+="uaccess"

ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="04d8", ATTR{idProduct}=="00de", \
    RUN+="/bin/sh -c 'echo -n %k:1.0 > /sys/bus/usb/drivers/usbhid/unbind 2>/dev/null || true'"
